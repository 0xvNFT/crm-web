# Copy this to .env.development for local dev
#
# Dev: leave VITE_API_BASE_URL empty — Vite proxy in vite.config.ts forwards /api to the backend.
# This avoids cross-origin cookie issues (localhost cannot send cookies to a remote IP).
#
# If running backend locally: set to http://localhost:8080 (same origin — no proxy needed)
# If pointing at prod backend: leave empty (use proxy)

VITE_API_BASE_URL=

# Backend URL for the Vite dev proxy — only used in development, never exposed to the browser
VITE_DEV_PROXY_TARGET=https://your-backend-url.com

# Set to 'false' to hide the "Create account" link on the login page (single-tenant deployments)
VITE_REGISTRATION_ENABLED=true

# Set to 'false' to hide the Billing nav item and route (single-tenant deployments)
VITE_BILLING_ENABLED=true
